  "info": {
    "_postman_id": "cc0f5385-2065-4766-8103-3858bc74c08d",
    "name": "Fastly AI Accelerator",
    "description": "Fastly AI Accelerator is a semantic caching solution that boosts the\nperformance of popular LLMs like OpenAI and Google Gemini by 9x. Semantic\ncaching maps queries to concepts as vectors so the system can cache answers\nto similar questions regardless of exact wording. AI Accelerator exposes\ndrop-in compatible chat completions endpoints that proxy to upstream\nproviders while serving cached responses from the edge.\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T15:09:00.000Z",
    "updatedAt": "2026-06-05T15:09:00.000Z",
