{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/DdosRule",
  "title": "DdosRule",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "block",
        "challenge",
        "log"
      ]
    },
    "match": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean"
    }
  }
}