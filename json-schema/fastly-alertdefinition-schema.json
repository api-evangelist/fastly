{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/AlertDefinition",
  "title": "AlertDefinition",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "service_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "stats",
        "domains",
        "origins"
      ]
    },
    "metric": {
      "type": "string"
    },
    "evaluation_strategy": {
      "type": "object"
    },
    "integration_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}