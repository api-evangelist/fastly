{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Script",
  "title": "Script",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "host": {
      "type": "string"
    },
    "first_seen_at": {
      "type": "string",
      "format": "date-time"
    },
    "authorized": {
      "type": "boolean"
    }
  }
}