    "name": "Fastly Publishing (Fanout) API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Fastly Publishing API sends messages to Fanout subscribers. Fanout is\ndesigned to be GRIP-compatible, such that\nhttps://api.fastly.com/service/{service_id} can be used as a GRIP URL in\napplication configurations. Messages can be delivered to subscribers across\nHTTP responses, HTTP streams, and WebSocket connections.\n",
      "type": "text/plain"
    }
