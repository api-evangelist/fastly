  "item": [
    {
      "id": "8e4fd589-3aca-4b49-94a5-d483f957bf91",
      "name": "Purging",
      "description": {
        "content": "Operations for purging cached content from Fastly's edge network, including single URL purges, surrogate key purges, bulk surrogate key purges, and purge-all operations.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "6ce66e6c-1dbe-463e-94b8-d95bb82117f8",
          "name": "Purge a URL",
          "request": {
            "name": "Purge a URL",
            "description": {
              "content": "Instantly purges a single URL from Fastly's edge cache. The cached URL should be the full URL of the object to purge. Supports soft purge via the Fastly-Soft-Purge header, which marks the object as stale rather than removing it immediately.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "purge",
                ":cached_url"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<uri>",
                  "key": "cached_url",
                  "description": "(Required) The full URL of the cached object to purge."
                }
              ]
            },
            "header": [
              {
                "disabled": false,
                "description": "Set to 1 to perform a soft purge, which marks the cached object as stale rather than immediately removing it. Stale objects can still be served while a fresh copy is fetched from origin.",
                "key": "Fastly-Soft-Purge",
                "value": "<integer>"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null
          },
          "response": [
