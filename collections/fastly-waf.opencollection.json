          "docs": "Creates a new WAF firewall instance associated with a Fastly service."
        },
        {
          "info": {
            "name": "Get a WAF firewall",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.fastly.com/waf/firewalls/:firewall_id",
            "params": [
              {
                "name": "firewall_id",
                "value": "",
                "type": "path",
                "description": "The alphanumeric string identifying the WAF firewall."
              }
            ]
          },
          "docs": "Retrieves the details of a specific WAF firewall instance."
        },
        {
          "info": {
            "name": "Update a WAF firewall",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://api.fastly.com/waf/firewalls/:firewall_id",
            "params": [
              {
                "name": "firewall_id",
                "value": "",
                "type": "path",
                "description": "The alphanumeric string identifying the WAF firewall."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Updates the configuration of a specific WAF firewall instance."
        },
        {
          "info": {
            "name": "Delete a WAF firewall",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.fastly.com/waf/firewalls/:firewall_id",
            "params": [
              {
                "name": "firewall_id",
                "value": "",
                "type": "path",
                "description": "The alphanumeric string identifying the WAF firewall."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Deletes a specific WAF firewall instance."
        }
