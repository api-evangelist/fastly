  "info": {
    "_postman_id": "0ed52fde-40ee-4b99-8e9a-a1b8bc815e33",
    "name": "Fastly AI Accelerator",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Fastly AI Accelerator is a semantic caching solution that boosts the\nperformance of popular LLMs like OpenAI and Google Gemini by 9x. Semantic\ncaching maps queries to concepts as vectors so the system can cache answers\nto similar questions regardless of exact wording. AI Accelerator exposes\ndrop-in compatible chat completions endpoints that proxy to upstream\nproviders while serving cached responses from the edge.\n",
      "type": "text/plain"
    }
  }
