    "_postman_id": "98730053-d69d-493a-bee9-1331bfc365df",
    "name": "Fastly Load Balancing API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Fastly Load Balancing API spreads traffic across multiple backends\nautomatically. It exposes Directors bound to VCL service versions for locked\nconfigurations with multiple director groups, and Dynamic Server Pools that\nallow servers to be added or removed without activating new service versions.\n",
      "type": "text/plain"
    }
  }
